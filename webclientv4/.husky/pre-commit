#!/bin/sh

# Resolve main repo root — works in both main checkout and git worktrees.
# In a worktree, --git-common-dir returns the absolute path to the main .git dir.
# In the main checkout, it returns ".git" (relative), so cd ../ gives the repo root.
main_root="$(cd "$(git rev-parse --git-common-dir)/.." && pwd)"

# Ensure node_modules/.bin from main repo is on PATH so lint-staged, eslint,
# and prettier are available even when running in a worktree (which has no node_modules).
export PATH="$main_root/webclientv4/node_modules/.bin:$PATH"

worktree_root="$(git rev-parse --show-toplevel)"

# In worktrees, node_modules doesn't exist (it's gitignored). Symlink to main repo's copy
# so ESM plugin imports (eslint-plugin-vue etc.) resolve correctly. The symlink is itself
# gitignored and persists for the lifetime of the worktree.
if [ ! -e "$worktree_root/webclientv4/node_modules" ]; then
  ln -sfn "$main_root/webclientv4/node_modules" "$worktree_root/webclientv4/node_modules"
fi

# --- Vue: lint-staged (ESLint + Prettier on staged .ts/.vue files) ---
cd "$worktree_root/webclientv4" || { echo "pre-commit: can't cd to webclientv4"; exit 1; }
lint-staged
node tools/check-api-ownership.mjs || { echo "pre-commit: api ownership check failed"; exit 1; }

# --- Rails: run rspec for changed Ruby files ---
cd "$worktree_root" || { echo "pre-commit: can't cd to repo root"; exit 1; }

staged_files=$(git diff --cached --name-only --diff-filter=ACM)
staged_ruby_files=$(echo "$staged_files" | grep '^app/.*\.rb$' || true)
staged_spec_files=$(echo "$staged_files" | grep '^spec/.*_spec\.rb$' || true)

# Map app/ files to their corresponding spec files
mapped_specs=""
for file in $staged_ruby_files; do
  # app/models/foo.rb -> spec/models/foo_spec.rb
  # app/controllers/foo_controller.rb -> spec/controllers/foo_controller_spec.rb
  # app/services/foo.rb -> spec/services/foo_spec.rb
  spec_file=$(echo "$file" | sed 's|^app/|spec/|' | sed 's|\.rb$|_spec.rb|')
  if [ -f "$spec_file" ]; then
    mapped_specs="$mapped_specs $spec_file"
  fi
done

# Combine and deduplicate
all_specs=$(printf '%s\n' "$staged_spec_files" "$mapped_specs" | grep -v '^$' | sort -u || true)

if [ -n "$all_specs" ]; then
  echo "Running rspec for changed files..."
  echo "$all_specs"
  # shellcheck disable=SC2086 -- intentional word splitting: each line becomes a separate arg
  bundle exec rspec --fail-fast $all_specs
fi
